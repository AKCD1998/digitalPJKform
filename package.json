{
  "name": "digital-pjkform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
    "migrate": "npm run migrate --workspace backend",
    "seed": "npm run seed --workspace backend",
    "syncBranchesFromFiles": "npm run syncBranchesFromFiles --workspace backend",
    "syncPartTimePharmacists": "npm run syncPartTimePharmacists --workspace backend",
    "db:setup": "npm run db:setup --workspace backend"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
